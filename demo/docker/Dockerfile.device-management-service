FROM rust:1.85-slim AS builder
WORKDIR /build
RUN apt-get update && apt-get install -y pkg-config libssl-dev && rm -rf /var/lib/apt/lists/*
COPY Cargo.toml Cargo.lock ./
COPY proto        proto/
COPY pki          pki/
COPY device-management-service device-management-service/

RUN mkdir -p ota-service/src artifact-store/src robot-agent/src
RUN printf '[package]\nname="ota-service"\nversion="0.1.0"\nedition="2021"\n[[bin]]\nname="ota-service"\npath="src/main.rs"\n' \
        > ota-service/Cargo.toml && printf 'fn main(){}\n' > ota-service/src/main.rs
RUN printf '[package]\nname="artifact-store"\nversion="0.1.0"\nedition="2021"\n[[bin]]\nname="artifact-store"\npath="src/main.rs"\n' \
        > artifact-store/Cargo.toml && printf 'fn main(){}\n' > artifact-store/src/main.rs
RUN printf '[package]\nname="robot-agent"\nversion="0.1.0"\nedition="2021"\n[[bin]]\nname="robot-agent"\npath="src/main.rs"\n' \
        > robot-agent/Cargo.toml && printf 'fn main(){}\n' > robot-agent/src/main.rs

RUN cargo build --release -p device-management-service

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*
COPY --from=builder /build/target/release/device-management-service /usr/local/bin/
EXPOSE 8443 8444
ENTRYPOINT ["device-management-service"]
